{
  "extends": "next/core-web-vitals",
  "ignorePatterns": ["!**/*"],
    "overrides": [
      {
        "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
        "parserOptions": {
            "project": ["./tsconfig(.*)?.json"],
            "ecmaFeatures": {
              "jsx": true
            }
        },
        "rules": {}
      },
      {
        "files": ["*.ts", "*.tsx"],
        "rules": {}
      },
      {
        "files": ["*.js", "*.jsx"],
        "rules": {}
      }
    ]
}
